# ============================================
# TELEGRAM BOT TOKEN
# ============================================
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ============================================
# PARSE MODE
# HTML atau Markdown
# ============================================
TELEGRAM_PARSE_MODE=HTML

# ============================================
# GOOGLE DRIVE FOLDER ID
# Folder ID dari Google Drive yang berisi spreadsheet
# ============================================
FOLDER_ID=your_google_drive_folder_id

# ============================================
# AI PROVIDER CONFIGURATION
# Pilihan: openai, gemini, ollama, groq
# ============================================
AI_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4

# Gemini Configuration (jika pakai Gemini)
GEMINI_API_KEY=your_gemini_api_key

# Ollama Configuration (jika pakai Ollama lokal)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Groq Configuration (jika pakai Groq)
GROQ_API_KEY=your_groq_api_key

# ============================================
# WEBHOOK CONFIGURATION (PRODUCTION)
# ============================================

# Aktifkan webhook mode (true untuk production)
WEBHOOK_MODE=true

# Domain/IP server production
# Ganti dengan domain atau IP VPS Anda
WEBHOOK_HOST=https://your-domain.com
# atau
# WEBHOOK_HOST=http://your-server-ip

# Path webhook (最好不要 ganti)
# WEBHOOK_PATH=/webhook/bot

# Secret token untuk verifikasi webhook (dibuat sendiri)
# Buat string acak yang aman, contoh: openssl rand -hex 32
WEBHOOK_SECRET=your_webhook_secret_token_min_32_chars

# Server binding
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ============================================
# DATABASE CONFIGURATION (DIROPS - Consolidated)
# ============================================
# Use SQLite for local development, PostgreSQL/MySQL for production

# Option 1: Direct DATABASE_URL (takes precedence)
# DATABASE_URL=postgresql://user:password@localhost:5432/dirops
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/dirops
# DATABASE_URL=sqlite:///path/to/dirops.db

# Option 2: Individual settings (used when DATABASE_URL not set)
# Database type: sqlite, postgresql, or mysql
DB_TYPE=postgresql

# PostgreSQL settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dirops
DB_USER=postgres
DB_PASSWORD=postgres

# MySQL settings (alternative to PostgreSQL)
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=root

# SQLite settings
# DB_NAME=dirops.db

# Flask environment
FLASK_ENV=production

# ============================================
# GOOGLE SERVICE ACCOUNT (JSON)
# Letakkan file credentials.json di direktori yang sama
# ============================================
