# Environment Configuration

# Database Type: sqlite, postgresql, mysql
DB_TYPE=sqlite

# SQLite
DB_NAME=dirops.db

# PostgreSQL (uncomment and configure if using PostgreSQL)
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=dirops
# DB_USER=postgres
# DB_PASSWORD=postgres

# MySQL (uncomment and configure if using MySQL)
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=dirops
# DB_USER=root
# DB_PASSWORD=root

# Flask Environment: development, production, test
FLASK_ENV=development

# Secret Key
SECRET_KEY=your-secret-key-change-in-production
